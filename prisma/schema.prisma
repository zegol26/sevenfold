generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum ResourceKind {
  CANDIDATE
  EMPLOYEE
  CONTRACTOR
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  VOID
  PAID
  OVERDUE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

model Role {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  description    String?
  permissions    Json     @default("[]")
  status         String   @default("active")
  legacySourceId String?  @unique
  users          User[]
  userRoles      UserRole[]
  rolePermissions RolePermission[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  fullName       String
  passwordHash   String?
  status         UserStatus @default(ACTIVE)
  roleId         String
  role           Role       @relation(fields: [roleId], references: [id])
  clientId       String?
  client         Client?    @relation(fields: [clientId], references: [id])
  resourceId     String?    @unique
  resource       Resource?  @relation(fields: [resourceId], references: [id])
  legacySourceId String?    @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  auditLogs      AuditLog[]
  userRoles      UserRole[]
}

model Permission {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  module          String
  description     String?
  status          String   @default("active")
  rolePermissions RolePermission[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([module, status])
  @@map("permissions")
}

model UserRole {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])
  scopeType     String?
  scopeId       String?
  status        String   @default("active")
  assignedBy    String?
  assignedAt    DateTime @default(now())
  revokedAt     DateTime?
  reason        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId, status])
  @@index([roleId, status])
  @@map("user_roles")
}

model RolePermission {
  id            String     @id @default(cuid())
  roleId        String
  role          Role       @relation(fields: [roleId], references: [id])
  permissionId  String
  permission    Permission @relation(fields: [permissionId], references: [id])
  status        String     @default("active")
  grantedBy     String?
  grantedAt     DateTime   @default(now())
  reason        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([roleId, permissionId])
  @@index([roleId, status])
  @@map("role_permissions")
}

model UserAccessPolicy {
  id                String   @id @default(cuid())
  subject           String
  subjectType       String
  resourceType      String
  resourceScope     String
  effect            String
  workflow          String?
  condition         Json?
  status            String   @default("active")
  reason            String?
  approvalReference String?
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([subjectType, subject])
  @@index([resourceType, status])
  @@map("user_access_policies")
}

model Client {
  id             String           @id @default(cuid())
  code           String           @unique
  name           String
  status         String           @default("active")
  legacySourceId String?          @unique
  contacts       ClientContact[]
  projects       Project[]
  users          User[]
  assignments    Assignment[]
  invoices       Invoice[]
  feedbacks      ClientFeedback[]
  grRecords      GrRecord[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  title     String?
  isPrimary Boolean  @default(false)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Project {
  id             String               @id @default(cuid())
  clientId       String
  client         Client               @relation(fields: [clientId], references: [id])
  code           String
  name           String
  currency       String               @default("USD")
  startDate      DateTime?
  endDate        DateTime?
  status         String               @default("active")
  legacySourceId String?              @unique
  assignments    Assignment[]
  applications   ProjectApplication[]
  invoices       Invoice[]
  feedbacks      ClientFeedback[]
  grRecords      GrRecord[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([clientId, code])
  @@index([clientId])
}

model Resource {
  id                               String               @id @default(cuid())
  kind                             ResourceKind         @default(CANDIDATE)
  fullName                         String
  email                            String?
  phone                            String?
  position                         String?
  status                           String               @default("active")
  candidateStage                   String?
  employmentType                   String?
  joinDate                         DateTime?
  endDate                          DateTime?
  assignedClientLegacyId           String?
  assignedProjectLegacyId          String?
  sourceCandidateLegacyId          String?
  contractStatus                   String?
  driveFolderId                    String?
  ndaAcknowledgedAt                DateTime?
  codeOfEthicsAcknowledgedAt       DateTime?
  dataPrivacyConsentAcknowledgedAt DateTime?
  onboardingTrainingCompletedAt    DateTime?
  resourceReadyAt                  DateTime?
  contractType                     String?
  contractNumber                   String?
  contractStartDate                DateTime?
  contractEndDate                  DateTime?
  baseSalary                       Decimal?             @db.Decimal(18, 2)
  allowanceAmount                  Decimal?             @db.Decimal(18, 2)
  grossMonthlySalary               Decimal?             @db.Decimal(18, 2)
  dailyRate                        Decimal?             @db.Decimal(18, 2)
  hourlyRate                       Decimal?             @db.Decimal(18, 2)
  clientBillRate                   Decimal?             @db.Decimal(18, 2)
  managementFeeRate                Decimal?             @db.Decimal(7, 4)
  managementFeeAmount              Decimal?             @db.Decimal(18, 2)
  recruitmentFee                   Decimal?             @db.Decimal(18, 2)
  taxType                          String?
  taxRate                          Decimal?             @db.Decimal(7, 4)
  pph21Amount                      Decimal?             @db.Decimal(18, 2)
  pph23Amount                      Decimal?             @db.Decimal(18, 2)
  bpjsKesehatanRate                Decimal?             @db.Decimal(7, 4)
  bpjsKesehatanAmount              Decimal?             @db.Decimal(18, 2)
  bpjsTkRate                       Decimal?             @db.Decimal(7, 4)
  bpjsTkAmount                     Decimal?             @db.Decimal(18, 2)
  netPayEstimate                   Decimal?             @db.Decimal(18, 2)
  invoiceAmountEstimate            Decimal?             @db.Decimal(18, 2)
  commercialNotes                  String?
  legacySourceId                   String?              @unique
  user                             User?
  assignments                      Assignment[]
  applications                     ProjectApplication[]
  feedbacks                        ClientFeedback[]     @relation("CandidateFeedbacks")
  timesheets                       Timesheet[]
  overtimeRequests                 OvertimeRequest[]
  leaveRequests                    LeaveRequest[]
  createdAt                        DateTime             @default(now())
  updatedAt                        DateTime             @updatedAt

  @@index([email])
  @@index([kind, status])
}

model Assignment {
  id               String            @id @default(cuid())
  resourceId       String
  resource         Resource          @relation(fields: [resourceId], references: [id])
  clientId         String
  client           Client            @relation(fields: [clientId], references: [id])
  projectId        String
  project          Project           @relation(fields: [projectId], references: [id])
  roleTitle        String?
  startDate        DateTime?
  endDate          DateTime?
  status           String            @default("active")
  legacySourceId   String?           @unique
  timesheets       Timesheet[]
  overtimeRequests OvertimeRequest[]
  leaveRequests    LeaveRequest[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([resourceId])
  @@index([projectId])
}

model ClientFeedback {
  id              String   @id @default(cuid())
  candidateId     String
  candidate       Resource @relation("CandidateFeedbacks", fields: [candidateId], references: [id])
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])
  reviewerUserId  String?
  rating          Int?
  decision        String
  comment         String
  rejectionReason String?
  status          String   @default("active")
  legacySourceId  String?  @unique
  submittedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([candidateId])
  @@index([clientId])
}

model Timesheet {
  id                   String      @id @default(cuid())
  resourceId           String
  resource             Resource    @relation(fields: [resourceId], references: [id])
  assignmentId         String?
  assignment           Assignment? @relation(fields: [assignmentId], references: [id])
  periodStart          DateTime?
  periodEnd            DateTime?
  totalHours           Decimal     @default(0) @db.Decimal(12, 2)
  nexusReviewStatus    String      @default("PENDING")
  clientApprovalStatus String      @default("PENDING")
  rejectionReason      String?
  status               String      @default("submitted")
  legacySourceId       String?     @unique
  submittedAt          DateTime?
  lockedAt             DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([resourceId])
  @@index([assignmentId])
}

model OvertimeRequest {
  id                    String      @id @default(cuid())
  resourceId            String
  resource              Resource    @relation(fields: [resourceId], references: [id])
  assignmentId          String?
  assignment            Assignment? @relation(fields: [assignmentId], references: [id])
  requestDate           DateTime?
  startAt               DateTime?
  endAt                 DateTime?
  hours                 Decimal     @default(0) @db.Decimal(12, 2)
  reason                String?
  nexusValidationStatus String      @default("PENDING")
  clientApprovalStatus  String      @default("PENDING")
  linkedTimesheetId     String?
  rejectionReason       String?
  status                String      @default("submitted")
  legacySourceId        String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([resourceId])
  @@index([assignmentId])
}

model LeaveRequest {
  id                   String      @id @default(cuid())
  resourceId           String
  resource             Resource    @relation(fields: [resourceId], references: [id])
  assignmentId         String?
  assignment           Assignment? @relation(fields: [assignmentId], references: [id])
  leaveType            String
  startDate            DateTime?
  endDate              DateTime?
  totalDays            Decimal     @default(0) @db.Decimal(8, 2)
  reason               String?
  hrReviewStatus       String      @default("PENDING")
  clientApprovalStatus String      @default("PENDING")
  timesheetImpact      String?
  rejectionReason      String?
  status               String      @default("submitted")
  legacySourceId       String?     @unique
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([resourceId])
  @@index([assignmentId])
}

model GrRecord {
  id                      String    @id @default(cuid())
  clientId                String
  client                  Client    @relation(fields: [clientId], references: [id])
  projectId               String?
  project                 Project?  @relation(fields: [projectId], references: [id])
  periodMonth             String
  workSummary             String?
  approvedTimesheetIds    String?
  serviceAcceptanceStatus String    @default("DRAFT")
  driveFileId             String?
  status                  String    @default("active")
  legacySourceId          String?   @unique
  invoices                Invoice[]
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([clientId])
  @@index([projectId])
}

model ProjectApplication {
  id               String    @id @default(cuid())
  resourceId       String
  resource         Resource  @relation(fields: [resourceId], references: [id])
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id])
  roleInterest     String?
  availabilityDate DateTime?
  notes            String?
  status           String    @default("submitted")
  legacySourceId   String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Invoice {
  id                   String        @id @default(cuid())
  clientId             String
  client               Client        @relation(fields: [clientId], references: [id])
  projectId            String?
  project              Project?      @relation(fields: [projectId], references: [id])
  grRecordId           String?
  grRecord             GrRecord?     @relation(fields: [grRecordId], references: [id])
  invoiceNumber        String        @unique
  currency             String        @default("IDR")
  invoiceDate          DateTime?
  dueDate              DateTime?
  subtotal             Decimal       @default(0) @db.Decimal(18, 2)
  taxAmount            Decimal       @default(0) @db.Decimal(18, 2)
  managementFeeAmount  Decimal       @default(0) @db.Decimal(18, 2)
  recruitmentFeeAmount Decimal       @default(0) @db.Decimal(18, 2)
  totalAmount          Decimal       @default(0) @db.Decimal(18, 2)
  status               InvoiceStatus @default(DRAFT)
  paymentStatus        PaymentStatus @default(UNPAID)
  generatedDocumentId  String?       @unique
  generatedDocument    Document?     @relation("GeneratedInvoiceDocument", fields: [generatedDocumentId], references: [id])
  legacySourceId       String?       @unique
  items                InvoiceItem[]
  payments             Payment[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([clientId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal  @default(0) @db.Decimal(18, 2)
  taxRate     Decimal  @default(0) @db.Decimal(7, 4)
  lineTotal   Decimal  @default(0) @db.Decimal(18, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id        String    @id @default(cuid())
  invoiceId String
  invoice   Invoice   @relation(fields: [invoiceId], references: [id])
  amount    Decimal   @db.Decimal(18, 2)
  currency  String    @default("IDR")
  paidAt    DateTime?
  reference String?
  status    String    @default("recorded")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Document {
  id             String   @id @default(cuid())
  driveFileId    String   @unique
  fileName       String
  mimeType       String
  fileSize       BigInt?
  documentType   String
  entityType     String
  entityId       String
  folderPath     String?
  version        Int      @default(1)
  status         String   @default("active")
  createdBy      String?
  updatedBy      String?
  legacySourceId String?  @unique
  invoice        Invoice? @relation("GeneratedInvoiceDocument")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([documentType, status])
}

model DocumentTemplate {
  id           String   @id @default(cuid())
  driveFileId  String   @unique
  name         String
  documentType String
  mimeType     String
  folderPath   String?
  version      Int      @default(1)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model SystemSetting {
  id             String   @id @default(cuid())
  key            String   @unique
  value          Json
  description    String?
  status         String   @default("active")
  legacySourceId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FrameworkSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  ownerRole   String?
  status      String   @default("active")
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("framework_settings")
}

model FrameworkVersion {
  id                String   @id @default(cuid())
  version           String   @unique
  description       String?
  snapshot          Json
  effectiveAt       DateTime?
  status            String   @default("draft")
  createdBy         String?
  approvedBy        String?
  approvalReference String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("framework_versions")
}

model DealTypeCriterion {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  criteria        String
  minValueUsd     Decimal? @db.Decimal(18, 2)
  maxValueUsd     Decimal? @db.Decimal(18, 2)
  sponsorOverride Boolean  @default(false)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CommodityCode {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RiskDomain {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CurrencySetting {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  rateToUsd    Decimal? @db.Decimal(18, 8)
  refreshedAt  DateTime?
  refreshSource String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ApprovalThreshold {
  id          String   @id @default(cuid())
  decision    String
  role        String
  minValueUsd Decimal  @default(0) @db.Decimal(18, 2)
  maxValueUsd Decimal? @db.Decimal(18, 2)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([decision, status])
}

model ApprovalMatrix {
  id          String   @id @default(cuid())
  workflow    String
  decision    String
  description String?
  status      String   @default("active")
  createdBy   String?
  updatedBy   String?
  rules       ApprovalRule[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workflow, decision])
  @@index([workflow, status])
  @@map("approval_matrices")
}

model ApprovalRule {
  id                String   @id @default(cuid())
  matrixId          String
  matrix            ApprovalMatrix @relation(fields: [matrixId], references: [id])
  sequence          Int
  approverRole      String
  condition         Json?
  required          Boolean  @default(true)
  escalationRole    String?
  status            String   @default("active")
  reason            String?
  approvalReference String?
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([matrixId, sequence, approverRole])
  @@index([matrixId, status])
  @@map("approval_rules")
}

model Opportunity {
  id                   String   @id @default(cuid())
  opportunityCode       String   @unique
  customerName          String
  customerSegment       String?
  accountManager        String?
  solutionArchitect     String?
  dealType              String?
  targetSubmissionDate  DateTime?
  expectedContractStart DateTime?
  expectedContractEnd   DateTime?
  scopeSummary          String?
  status                String   @default("draft")
  pricingApprovedAt     DateTime?
  pricingApprovedBy     String?
  createdBy             String?
  updatedBy             String?
  scenarios             ProposalScenario[]
  risks                 RiskRegister[]
  pricingDecisions      PricingDecision[]
  cashflowOptions       CashflowOption[]
  sdsApprovals          SalesDecisionSubmission[]
  sdoaApprovals         OrderAcknowledgement[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status])
  @@index([dealType])
}

model ProposalScenario {
  id            String   @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  scenarioCode  String
  name          String
  description   String?
  currency      String   @default("USD")
  totalCost     Decimal  @default(0) @db.Decimal(18, 2)
  totalPrice    Decimal  @default(0) @db.Decimal(18, 2)
  grossMargin   Decimal? @db.Decimal(7, 4)
  status        String   @default("draft")
  commodityLines ProposalCommodityLine[]
  pricingDecisions PricingDecision[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([opportunityId, scenarioCode])
  @@index([opportunityId])
}

model ProposalCommodityLine {
  id              String   @id @default(cuid())
  scenarioId       String
  scenario         ProposalScenario @relation(fields: [scenarioId], references: [id])
  commodityCode    String
  description      String?
  quantity         Decimal  @default(1) @db.Decimal(12, 2)
  unitCost         Decimal  @default(0) @db.Decimal(18, 2)
  unitPrice        Decimal  @default(0) @db.Decimal(18, 2)
  resourceCost     Decimal  @default(0) @db.Decimal(18, 2)
  partnerCost      Decimal  @default(0) @db.Decimal(18, 2)
  procurementCost  Decimal  @default(0) @db.Decimal(18, 2)
  projectCost      Decimal  @default(0) @db.Decimal(18, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([scenarioId])
  @@index([commodityCode])
}

model RiskRegister {
  id                    String   @id @default(cuid())
  opportunityId          String
  opportunity            Opportunity @relation(fields: [opportunityId], references: [id])
  riskCode               String
  domain                 String
  commodityCode          String?
  description            String
  probabilityScore       Decimal? @db.Decimal(8, 4)
  impactCost             Decimal  @default(0) @db.Decimal(18, 2)
  mitigationPlan         String?
  mitigationCost         Decimal  @default(0) @db.Decimal(18, 2)
  residualExposure       Decimal  @default(0) @db.Decimal(18, 2)
  riskCostAfterMitigation Decimal @default(0) @db.Decimal(18, 2)
  predictedOccurrenceDate DateTime?
  severity               String?
  status                 String   @default("open")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([opportunityId, riskCode])
  @@index([opportunityId])
  @@index([domain])
}

model PricingDecision {
  id            String   @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  scenarioId    String?
  scenario      ProposalScenario? @relation(fields: [scenarioId], references: [id])
  decision      String
  approvedBy    String?
  approvedAt    DateTime?
  comment       String?
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([opportunityId])
}

model CashflowOption {
  id              String   @id @default(cuid())
  opportunityId   String
  opportunity     Opportunity @relation(fields: [opportunityId], references: [id])
  optionCode      String
  name            String
  currency        String   @default("USD")
  dsoDays         Int      @default(30)
  grossInvoice    Decimal  @default(0) @db.Decimal(18, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(18, 2)
  withholdingTax  Decimal  @default(0) @db.Decimal(18, 2)
  cashGap         Decimal  @default(0) @db.Decimal(18, 2)
  marginAmount    Decimal  @default(0) @db.Decimal(18, 2)
  npv             Decimal? @db.Decimal(18, 2)
  approvedBy      String?
  approvedAt      DateTime?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([opportunityId, optionCode])
  @@index([opportunityId])
}

model SalesDecisionSubmission {
  id               String   @id @default(cuid())
  opportunityId     String
  opportunity       Opportunity @relation(fields: [opportunityId], references: [id])
  customerValue     String?
  companyValue      String?
  upsellOpportunity String?
  growthAspect      String?
  selectedScenario  String?
  selectedCashflow  String?
  deliveryCapability String?
  pptDocumentId     String?
  decision          String   @default("pending")
  sponsor           String?
  decidedAt         DateTime?
  comment           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([opportunityId])
}

model OrderAcknowledgement {
  id              String   @id @default(cuid())
  opportunityId    String
  opportunity      Opportunity @relation(fields: [opportunityId], references: [id])
  receivedPoNumber String?
  contractDocumentId String?
  outcome         String   @default("pending")
  sponsor         String?
  decidedAt       DateTime?
  comment         String?
  deviations      ContractDeviation[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([opportunityId])
}

model ContractDeviation {
  id                     String   @id @default(cuid())
  orderAcknowledgementId  String
  orderAcknowledgement    OrderAcknowledgement @relation(fields: [orderAcknowledgementId], references: [id])
  category               String
  baselineValue          String?
  receivedValue          String?
  decision               String   @default("requires_clarification")
  comment                String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([orderAcknowledgementId])
}

model ProjectGovernance {
  id                       String   @id @default(cuid())
  projectCode               String   @unique
  opportunityCode           String?
  orderAcknowledgementId    String?
  sponsor                   String?
  projectManager            String?
  programDirector           String?
  projectFinanceManager     String?
  resourceManager           String?
  supplyManager             String?
  procurementManager        String?
  scheduleStatus            String   @default("green")
  scopeStatus               String   @default("green")
  costStatus                String   @default("green")
  qualityStatus             String   @default("green")
  riskStatus                String   @default("green")
  acceptanceStatus          String   @default("pending")
  grStatus                  String   @default("pending")
  invoiceStatus             String   @default("pending")
  netSalesEstimate          Decimal  @default(0) @db.Decimal(18, 2)
  status                    String   @default("draft")
  gates                     ProjectGate[]
  resourcePlans             ResourcePlan[]
  governanceBoards          GovernanceBoard[]
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([opportunityCode])
}

model ProjectGate {
  id                  String   @id @default(cuid())
  projectGovernanceId  String
  projectGovernance    ProjectGovernance @relation(fields: [projectGovernanceId], references: [id])
  gateNumber          Int
  gateName            String
  entryCriteria       String?
  outputEvidence      String?
  initiatedBy         String?
  approvedBy          String?
  approvedAt          DateTime?
  decision            String   @default("pending")
  comment             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([projectGovernanceId, gateNumber])
}

model ResourcePlan {
  id                  String   @id @default(cuid())
  projectGovernanceId  String
  projectGovernance    ProjectGovernance @relation(fields: [projectGovernanceId], references: [id])
  role                String
  skill               String?
  location            String?
  source              String?
  plannedStart        DateTime?
  plannedEnd          DateTime?
  allocationPercent   Decimal  @default(100) @db.Decimal(7, 2)
  ratecardReference   String?
  blendedCostReference String?
  availability        String?
  onboardingStatus    String?
  resourceRisk        String?
  replacementPlan     String?
  status              String   @default("planned")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([projectGovernanceId])
}

model GovernanceBoard {
  id                  String   @id @default(cuid())
  projectGovernanceId  String?
  projectGovernance    ProjectGovernance? @relation(fields: [projectGovernanceId], references: [id])
  boardType           String
  cadence             String
  meetingDate         DateTime?
  chair               String?
  participants        Json     @default("[]")
  agenda              String?
  decisions           String?
  actionItems         Json     @default("[]")
  escalationStatus    String   @default("none")
  evidenceDocumentId  String?
  status              String   @default("draft")
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([boardType, meetingDate])
  @@index([projectGovernanceId])
}

model TalentProfile {
  id                              String   @id @default(cuid())
  importBatchId                    String?
  name                            String
  age                             Int?
  gender                          String?
  currentRole                     String?
  expectedRole                    String?
  riskForLeaving                  String?
  impact                          String?
  note                            String?
  readiness                       String?
  successorCandidateForRole       String?
  certificationRequirement        String?
  developmentAction               String?
  retentionRiskMitigation         String?
  status                          String   @default("active")
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  @@index([currentRole])
  @@index([expectedRole])
}

model Ratecard {
  id                       String   @id @default(cuid())
  ratecardCode              String   @unique
  resourceType              String
  location                  String?
  source                    String?
  currency                  String   @default("USD")
  netAccrualSalaryMonthly   Decimal  @default(0) @db.Decimal(18, 2)
  productiveHoursMonthly    Decimal  @default(160) @db.Decimal(8, 2)
  absorbedMonthlyCost       Decimal  @default(0) @db.Decimal(18, 2)
  absorbedHourlyCost        Decimal  @default(0) @db.Decimal(18, 2)
  operationalMarkupPercent  Decimal  @default(0) @db.Decimal(7, 4)
  recommendedHourlyCost     Decimal  @default(0) @db.Decimal(18, 2)
  status                    String   @default("draft")
  approvedBy                String?
  approvedAt                DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([resourceType, location])
}
